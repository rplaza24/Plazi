{
  "gimbal": {
    "port": "/dev/ttyTHS1",
    "baud_rate": 115200,
    "protocol": "simulation",
    "pan_limits": [-90, 90],
    "tilt_limits": [-45, 45],
    "center_position": [0, 0]
  },
  "tracking": {
    "pid_pan": {
      "kp": 0.8,
      "ki": 0.01,
      "kd": 0.15
    },
    "pid_tilt": {
      "kp": 0.8,
      "ki": 0.01,
      "kd": 0.15
    },
    "deadzone": 5,
    "max_speed": 30,
    "smoothing_factor": 0.7
  },
  "target_selection": {
    "priority": "largest",
    "min_face_size": 50,
    "target_emotions": ["happy", "surprise"],
    "confidence_threshold": 0.6
  }
}
